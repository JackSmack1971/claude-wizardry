{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "version": 1,
  "theme": "system",
  "model": "sonnet",
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/node_modules/**)",
      "Read(**/.git/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/__pycache__/**)"
    ]
  },
  "tools": {
    "shell": {
      "enabled": true,
      "timeoutSeconds": 60
    },
    "git": {
      "enabled": true,
      "protectBranches": [
        "main",
        "master"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-tool-use.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
